<Control xmlns="https://spacestation14.io"
         xmlns:mini="clr-namespace:Content.Client.UserInterface"
         MinWidth="300" MaxWidth="500">
    <PanelContainer StyleClasses="AngleRect" />
    <BoxContainer Margin="4" Orientation="Vertical">
        <Label Name="VoteCaller" />
        <RichTextLabel Name="VoteTitle" />
        <Button Margin="4 4" Name="FollowVoteTarget" Text="{Loc 'ui-vote-follow-button-popup'}" Visible="False"></Button>

        <GridContainer Columns="2" Name="VoteOptionsContainer"/>
        <BoxContainer Orientation="Horizontal" VerticalAlignment="Center" Margin="4 6 4 2" HorizontalAlignment="Left">
            <mini:PixelScrollProgressBar Name="TimeLeftBar" Access="Public" />
            <Label Name="TimeLeftText" Margin="8 0 0 0" VerticalAlignment="Center" />
        </BoxContainer>
    </BoxContainer>
</Control>
