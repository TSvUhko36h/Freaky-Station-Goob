<BoxContainer
    xmlns="https://spacestation14.io"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:amour="clr-namespace:Content.Client._Amour.Stickers.UI"
    xmlns:goobcontrols="clr-namespace:Content.Goobstation.UIKit.UserInterface.Controls;assembly=Content.Goobstation.UIKit"
    Orientation="Vertical"
    HorizontalExpand="True"
    VerticalExpand="True"
    SeparationOverride="6">
    <PanelContainer
        StyleClasses="StyleNano.StyleClassChatPanel"
        HorizontalExpand="True"
        VerticalExpand="True">
        <BoxContainer
            Orientation="Vertical"
            SeparationOverride="4"
            HorizontalExpand="True"
            VerticalExpand="True">
            <goobcontrols:CustomOutputPanel
                Name="TextOutput"
                StyleClasses="StyleNano.StyleClassChatOutput"
                HorizontalExpand="True"
                VerticalExpand="True"
                Margin="8 8 8 4" />
            <RichTextLabel Name="TypingIndicator" Access="Public" />
            <BoxContainer Name="RatingHost" Orientation="Vertical" HorizontalExpand="True" />
        </BoxContainer>
    </PanelContainer>
    <!-- Amour edit start -->
    <BoxContainer
        Orientation="Horizontal"
        HorizontalExpand="True"
        SeparationOverride="4"
        Margin="2 0 2 2">
        <HistoryLineEdit
            Name="SenderLineEdit"
            StyleClasses="actionSearchBox"
            HorizontalExpand="True"
            MinHeight="36" />
        <amour:StickerButton Name="StickerBtn" />
    </BoxContainer>
    <!-- Amour edit end -->
    <RichTextLabel Name="RelayedToDiscordLabel" Access="Public" Visible="False" />
</BoxContainer>
