<Control xmlns="https://spacestation14.io"
         MinHeight="28">
    <GridContainer Columns="3" HorizontalExpand="True">
        <Label Name="NameLabel"
               MinWidth="280" MaxWidth="280"
               ClipText="True"
               VerticalAlignment="Center" />
        <Slider Name="Slider" Access="Public"
                MinWidth="160" MaxWidth="160"
                HorizontalAlignment="Center"
                VerticalAlignment="Center" />
        <Label Name="ValueLabel" Access="Public"
               MinWidth="52" MaxWidth="52"
               Align="Right"
               VerticalAlignment="Center" />
    </GridContainer>
</Control>
