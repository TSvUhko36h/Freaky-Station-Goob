# Compact card text for Typan station goal objectives (character menu).

typan-station-goal-objective-default-title = Station goal
typan-station-goal-objective-default-desc = Complete the order received by fax from Typan command.
typan-station-goal-objective-task-title = Special task «{$name}»

station-goal-syndicate-maid-card-title = Special task «Spy»
station-goal-syndicate-maid-card-desc =
    Objective: Obtain intelligence on a restricted-access corporate station.
    Cover: Infiltrate as an assistant in the NT command staff residence.
    Tasks: send operatives, contact command, gather intel, abduct and extract the target to Typan.

station-goal-syndicate-ai-card-title = Special task «AI Capture»
station-goal-syndicate-ai-card-desc =
    Objective: Gain control of the station AI core and record it to an intellicard.
    Cover: Infiltrate as an AI systems maintenance specialist.
    Tasks: send 3–4 operatives, access the core, transport the core/intellicard to Typan.

station-goal-syndicate-cargo-card-title = Special task «Expand Typan Fleet»
station-goal-syndicate-cargo-card-desc =
    Objective: Build a combat shuttle disguised as a commercial vessel for Syndicate operations.
    Cover: Infiltrate as a shipwright or cargo specialist.
    Tasks: send 2–3 operatives, hijack and arm a shuttle, covertly deliver it to Typan.

station-goal-syndicate-medical-card-title = Special task «Pandemic»
station-goal-syndicate-medical-card-desc =
    Objective: Infiltrate medical staff to infect senior command.
    Cover: Infiltrate as a doctor or virologist.
    Tasks: send two operatives, spread infection, return to Typan unnoticed.

station-goal-syndicate-engineering-card-title = Special task «Shadow Reactor»
station-goal-syndicate-engineering-card-desc =
    Objective: Build a hidden power node masked as emergency backup in the station grid.
    Cover: Infiltrate as an engineer or atmospherics technician.
    Tasks: gather telecrystals, install an energy sink, tap main power lines covertly.
